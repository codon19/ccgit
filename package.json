{
  "name": "ccgit",
  "displayName": "ccgit",
  "description": "Zero-config AI commit message generator for Claude Code CLI users",
  "version": "0.1.0",
  "publisher": "songguanghui",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/songguanghui/ccgit"
  },
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18"
  },
  "categories": ["SCM Providers", "AI"],
  "keywords": ["git", "commit", "ai", "claude", "anthropic", "ccswitch"],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "activationEvents": [
    "onCommand:ccgit.generate",
    "onCommand:ccgit.openOutputPanel",
    "onCommand:ccgit.openConfigFile"
  ],
  "contributes": {},
  "scripts": {
    "build": "esbuild src/extension/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18 --sourcemap",
    "build:prod": "npm run build -- --minify --drop:debugger",
    "watch": "npm run build -- --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vscode-test",
    "package": "npm run build:prod && vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0"
  }
}
