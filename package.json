{
  "name": "ccgit",
  "displayName": "ccgit",
  "description": "Zero-config AI commit message generator for Claude Code CLI users",
  "version": "0.1.0",
  "publisher": "codon19",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/codon19/ccgit"
  },
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18"
  },
  "categories": ["SCM Providers", "AI"],
  "keywords": ["git", "commit", "ai", "claude", "anthropic", "ccswitch"],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "activationEvents": [
    "onCommand:ccgit.generate",
    "onCommand:ccgit.openOutputPanel",
    "onCommand:ccgit.openConfigFile"
  ],
  "contributes": {
    "commands": [
      {
        "command": "ccgit.generate",
        "title": "%cmd.generate.title%",
        "category": "ccgit",
        "icon": {
          "light": "images/icon-light.svg",
          "dark": "images/icon-dark.svg"
        }
      },
      {
        "command": "ccgit.openOutputPanel",
        "title": "%cmd.openOutput.title%",
        "category": "ccgit"
      },
      {
        "command": "ccgit.openConfigFile",
        "title": "%cmd.openConfig.title%",
        "category": "ccgit"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "ccgit.generate",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ]
    },
    "configuration": {
      "title": "ccgit",
      "properties": {
        "ccgit.model": {
          "type": "string",
          "default": "",
          "markdownDescription": "%cfg.model.desc%"
        },
        "ccgit.style.language": {
          "type": "string",
          "enum": ["auto", "english", "simplified-chinese", "traditional-chinese", "japanese", "korean"],
          "default": "auto",
          "markdownDescription": "%cfg.lang.desc%"
        },
        "ccgit.style.format": {
          "type": "string",
          "enum": ["auto", "conventional", "plain", "gitmoji"],
          "default": "auto",
          "markdownDescription": "%cfg.format.desc%"
        },
        "ccgit.diff.maxTokens": {
          "type": "number",
          "default": 12000,
          "minimum": 1000,
          "maximum": 100000,
          "markdownDescription": "%cfg.maxTokens.desc%"
        },
        "ccgit.customSystemPrompt": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "markdownDescription": "%cfg.customPrompt.desc%"
        },
        "ccgit.recentCommitsForStyle": {
          "type": "number",
          "default": 20,
          "minimum": 0,
          "maximum": 100,
          "markdownDescription": "%cfg.recentCommits.desc%"
        },
        "ccgit.baseUrl": {
          "type": "string",
          "default": "",
          "markdownDescription": "%cfg.baseUrl.desc%"
        },
        "ccgit.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "%cfg.apiKey.desc%"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18 --sourcemap",
    "build:prod": "npm run build -- --minify --drop:debugger",
    "watch": "npm run build -- --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vscode-test",
    "package": "npm run build:prod && vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0"
  }
}
